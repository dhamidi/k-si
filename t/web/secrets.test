# t/web/secrets.test — the /secrets management surface (docs/06, decision-004),
# driven through the REAL web.Server in-process (decision-008). A secret is stored
# by REFERENCE: the list, the audit trail, and every effect deal in secret:// URLs;
# the plaintext is written once at the web edge (SimSecrets.Set discards it) and
# NEVER re-rendered, logged, put in a message, or a URL. This scenario proves the
# whole loop — add, rotate, delete-through-confirm, invalid-add — and, critically,
# asserts the posted plaintext NEVER appears on the page (`lacks`). Host-gated, no
# token (decision-006). The sim leak-scan (SENTINEL) is the belt; `lacks` the braces.

send allow-sender { address kasi@decode.ee }

# --- empty state, and the Secrets nav on this page AND another (consistency) -----
visit /secrets matches "*No secrets stored yet*"
visit /secrets matches "*No changes recorded yet*"
# The ONE shared top-level navbar (site_nav.vue) now carries Secrets, in order,
# lit as the active section on this page.
visit /secrets matches "*Tasks*Skills*Memory*Apps*Store*Secrets*Settings*"
visit /secrets matches "*is-active*Secrets*"
# The nav is identical across pages: Secrets shows on another page too.
visit /tasks matches "*Tasks*Skills*Memory*Apps*Store*Secrets*Settings*"

# --- add a real credential through the real form ---------------------------------
# A realistic Fastmail API token — the kind of standing credential käsi needs to
# send mail. It is the plaintext we then assert can NEVER be found on the page.
post /secrets {
    namespace fastmail
    key       api-token
    value     fmu1-0xDEADBEEFcafef00d-2f9a4c1b7e6d
}

# The list shows the REFERENCE (name only), not the value; the trail shows a `set`.
visit /secrets matches "*secret://fastmail/api-token*"
visit /secrets matches "*set*secret://fastmail/api-token*"

# CRITICAL (decision-004): the plaintext value is NOWHERE on the page.
visit /secrets lacks "*fmu1-0xDEADBEEFcafef00d-2f9a4c1b7e6d*"
# Nor on the confirm-delete page for that reference.
visit /secrets/confirm-delete?ref=secret://fastmail/api-token lacks "*fmu1-0xDEADBEEFcafef00d-2f9a4c1b7e6d*"

# The name-only audit trail is in the credentials model (set op, reference only).
model credentials events matches "*set*secret://fastmail/api-token*"
model credentials events lacks "*fmu1-0xDEADBEEFcafef00d-2f9a4c1b7e6d*"

# --- rotate: setting the same reference again is still ONE row -------------------
post /secrets {
    namespace fastmail
    key       api-token
    value     fmu1-0xROTATEDvalue99887766-aa11bb22
}
# Still exactly one occurrence of the reference in the list region: assert the row
# is present and neither the old nor the new plaintext leaked.
visit /secrets matches "*secret://fastmail/api-token*"
visit /secrets lacks "*fmu1-0xDEADBEEFcafef00d-2f9a4c1b7e6d*"
visit /secrets lacks "*fmu1-0xROTATEDvalue99887766-aa11bb22*"

# --- delete through the confirm step --------------------------------------------
# The confirm page names the reference and offers a POST to the delete route.
visit /secrets/confirm-delete?ref=secret://fastmail/api-token matches "*Delete*secret://fastmail/api-token*"
visit /secrets/confirm-delete?ref=secret://fastmail/api-token matches "*Confirm delete*Cancel*"
# Confirm: POST the delete with the reference in the hidden field.
post /secrets/delete {
    ref secret://fastmail/api-token
}
# Gone from the list; the trail now shows a `removed` event for the reference.
visit /secrets matches "*No secrets stored yet*"
visit /secrets matches "*removed*secret://fastmail/api-token*"
model credentials events matches "*removed*secret://fastmail/api-token*"

# --- an invalid add re-renders 422 with an error and records NO set event -------
# A blank key: the form comes back with the namespace preserved and a key error,
# and the credentials trail gains no new `set`.
post /secrets {
    namespace fastmail
    key       ""
    value     never-stored-because-invalid
} matches "*a key is required*"
# The re-render preserved the namespace we typed…
post /secrets {
    namespace fastmail
    key       ""
    value     never-stored-because-invalid
} matches "*fastmail*"
# …and never the value.
post /secrets {
    namespace fastmail
    key       ""
    value     never-stored-because-invalid
} lacks "*never-stored-because-invalid*"
# Still nothing stored, and no set event for an empty key.
visit /secrets matches "*No secrets stored yet*"
